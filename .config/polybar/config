[colors]
nord0 = #2e3440
nord3 = #4c566a
nord4 = #d8dee9
nord8 = #88c0d0
nord10 = #5e81ac
nord11 = #bf616a
nord12 = #d08770
nord13 = #ebcb8b
nord14 = #a3be8c
nord15 = #b48ead

background = ${colors.nord0}
background-alt = #444
foreground = ${colors.nord4}
foreground-alt = ${colors.nord3}
primary = #ffb52a
secondary = #e60053
alert = ${colors.nord11}

[bar/bottom]
#monitor = ${env:MONITOR:eDP1}
width = 100%
height = 2.5%
radius = 6.0
fixed-center = false
bottom = true

background = ${colors.background}
foreground = ${colors.foreground}

border-size = 0
line-size = 2
padding = 1
module-margin = 1

font-0 = "FiraCode Nerd Font:size=10;1"
font-1 = "FiraCode Nerd Font:size=10;1"
font-2 = "FiraCode Nerd Font:size=10;1"
font-3 = "Material Design Icons:size=10;1"

modules-left = date i3 xwindow
modules-center =
modules-right = pulseaudio backlight eth1 wlan memory battery powermenu

tray-position = right
tray-padding = 2
tray-maxsize = 24

[global/wm]
margin-top = 0

[module/xwindow]
type = internal/xwindow
label = %title:0:70:...%

[module/battery]
type = internal/battery
full-at = 98

format-charging = <animation-charging>%{T3}<label-charging> %{T-}
format-discharging = <ramp-capacity>%{T3}<label-discharging> %{T-}

format-charging-underline = ${colors.nord14}
format-discharging-underline = ${colors.nord13}

format-full = ¾░éä%{T3}100%%{T-}
format-full-underline = ${colors.nord14}

label-charging-foreground = ${colors.foreground}
label-discharging-foreground = ${colors.foreground}

label-charging-font = 3
label-discharging-font = 3
label-full =  Charged

animation-charging-0 = ¾░ó£
animation-charging-1 = ¾░óØ
animation-charging-2 = ¾░éà
animation-charging-foreground = #009933
animation-charging-framerate = 900

ramp-capacity-0 = %{F#FF004B}¾░éâ%{F-}
ramp-capacity-1 = %{F#FF8000}¾░ü║%{F-}
ramp-capacity-2 = %{F#FF8000}¾░ü╗%{F-}
ramp-capacity-3 = %{F#FF8000}¾░ü╝%{F-}
ramp-capacity-4 = ¾░ü¢
ramp-capacity-5 = ¾░ü¥
ramp-capacity-6 = ¾░ü┐
ramp-capacity-7 = ¾░éÇ
ramp-capacity-8 = ¾░éü
ramp-capacity-9 = ¾░éé
ramp-capacity-10 = ¾░ü╣ 
ramp-capacity-foreground = ${colors.nord14}
ramp-capacity-framerate = 750


[module/backlight]
type = internal/backlight
#card = intel_backlight
card = acpi_video0
format = Brightness <label>
label = %percentage%%

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "¾░ıø"
format-prefix-foreground = ${colors.foreground-alt}
format-underline = #fb00ff
label = %percentage:2%%

[module/memory]
type = internal/memory
interval = 2
format-prefix = "¾░ıø"
format-prefix-foreground = ${colors.nord8}
format-underline = ${colors.nord8}
label = %gb_used%

[module/wlan]
type = internal/network
interface = ${env:WLAN}
interval = 5.0

format-connected = <ramp-signal> <label-connected>
format-connected-prefix = 
format-connected-prefix-foreground = ${colors.nord11}
format-connected-underline = ${colors.nord11}
label-connected = %essid%

format-disconnected = <label-disconnected>
format-disconnected-prefix = "Ô£ê "
label-disconnected = disconnected
label-disconnected-foreground = ${colors.foreground-alt}

ramp-signal-0 = %{F#ff9999}¾░ñ½%{F-}
ramp-signal-1 = %{F#ff9999}¾░ñş%{F-}
ramp-signal-2 =  ¾░ñ¿
ramp-signal-3 =  ¾░ñ¿
ramp-signal-4 =  ¾░ñ¿
ramp-signal-foreground = ${colors.nord11}

[module/eth1]
type = internal/network
interface = enp60s0
interval = 3.0

format-connected-underline = #ffb300
format-connected-prefix = "eth: "
format-connected-prefix-foreground = ${colors.foreground-alt}
label-connected = %local_ip%

format-disconnected =

[module/date]
type = internal/date
interval = 1

date = "%a %d"
date-alt = %a %b %d

time = %H:%M
time-alt = %H:%M:%S

format-prefix = "¾▒æå "
format-prefix-foreground = ${colors.nord15}
format-underline = ${colors.nord15}

label = %date% %time%

[settings]
screenchange-reload = true

[module/powermenu]
type = custom/menu

label-open = ÔÅ╗
label-close = x
label-separator = |

format-foreground = ${colors.nord11}

menu-0-0 = Logout 
menu-0-0-exec = i3-msg exit
menu-0-1 = Power Off 
menu-0-1-exec = poweroff
menu-0-2 = Reboot 
menu-0-2-exec = systemctl reboot

[module/pulseaudio]
type = internal/pulseaudio
sink = alsa_output.pci-0000_00_1f.3.analog-stereo

format-volume = <ramp-volume> <label-volume>
label-volume = %percentage%%
label-muted = "¾░Øş" muted
label-muted-foreground = ${colors.foreground-alt}
format-volume-underline = ${colors.nord12}

; Only applies if <ramp-volume> is used5
ramp-volume-0 = ¾░ò┐
ramp-volume-1 = ¾░ûÇ
ramp-volume-2 = ¾░ò¥
ramp-volume-foreground = ${colors.nord12}

[module/i3]
type = internal/i3
pin-workspaces = true

ws-icon-0 = 1;¾░ŞÀ
ws-icon-1 = 2;¾░ê╣
ws-icon-2 = 3;¾▒éÁ
ws-icon-3 = 4;¾░ò╝
ws-icon-4 = 5;¾░¿Ş
ws-icon-default = ¾░úç

format = <label-state> <label-mode>

label-mode = %mode%
label-mode-background = #e60053

label-focused = %icon%
label-focused-foreground = ${colors.background}
label-focused-background = ${colors.foreground}
label-focused-padding = 1 

label-unfocused = %icon%
label-unfocused-foreground = ${colors.foreground}
label-unfocused-background = ${colors.background}
label-unfocused-padding = 1

label-visible = %index%
label-visible-padding = 1

label-urgent = %icon%
label-urgent-foreground = #ffffff
label-urgent-background = #bd2c40
label-urgent-padding = 1
